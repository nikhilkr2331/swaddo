# SwaDDo Backend Production Environment Variables

# Server Configuration
PORT=5005
NODE_ENV=production

# Database Configuration (PostgreSQL)
# E.g. postgres://user:password@host:port/database
DATABASE_URL=PUT_YOUR_POSTGRES_DB_URL_HERE

# Authentication Secret (Change this to a strong, random 64-character string)
JWT_SECRET=PUT_YOUR_PRODUCTION_JWT_SECRET_HERE

# Razorpay Live Credentials
# You get these from your Razorpay Dashboard after submitting KYC
RAZORPAY_KEY_ID=PUT_YOUR_LIVE_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=PUT_YOUR_LIVE_RAZORPAY_KEY_SECRET_HERE

# Firebase Admin Credentials (for Push Notifications)
# Download the serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
# Base64 encode the JSON file and paste it here OR place the JSON file path
FIREBASE_SERVICE_ACCOUNT=PUT_YOUR_FIREBASE_SERVICE_ACCOUNT_CREDENTIALS_HERE

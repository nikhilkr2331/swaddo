# SwaDDo Customer App Environment Variables

# Backend API URL (Replace with your hosted backend URL, e.g. https://api.swaddo.com)
NEXT_PUBLIC_API_URL=http://localhost:5005/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5005

# Razorpay Keys (MUST match your Backend's Razorpay Account)
NEXT_PUBLIC_RAZORPAY_KEY_ID=PUT_YOUR_LIVE_RAZORPAY_KEY_ID_HERE

# Firebase Client Credentials (for Push Notifications)
# You get these from Firebase Console > Project Settings > General > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=PUT_YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=PUT_YOUR_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=PUT_YOUR_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=PUT_YOUR_FIREBASE_STORAGE_BUCKET
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=PUT_YOUR_FIREBASE_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=PUT_YOUR_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_VAPID_KEY=PUT_YOUR_FIREBASE_VAPID_KEY
